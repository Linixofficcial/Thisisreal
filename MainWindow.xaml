<Window x:Class="AircraftController.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Aircraft Controller" Height="400" Width="400">
    <Grid>
        <Label Content="Speed:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"/>
        <TextBox Name="SpeedTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,10,0,0" Width="200"/>

        <Label Content="Altitude:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,40,0,0"/>
        <TextBox Name="AltitudeTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,40,0,0" Width="200"/>

        <Label Content="Angle:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,70,0,0"/>
        <TextBox Name="AngleTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,70,0,0" Width="200"/>

        <Button Name="ConnectButton" Content="Connect" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,100,0,0" Width="100"/>
        <Button Name="CalculateButton" Content="Calculate" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="120,100,0,0" Width="100"/>

        <Label Content="Lift:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,140,0,0"/>
        <Label Name="LiftLabel" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,140,0,0" Width="200"/>

        <Label Content="Drag:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,170,0,0"/>
        <Label Name="DragLabel" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,170,0,0" Width="200"/>

        <Label Content="Thrust:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,200,0,0"/>
        <Label Name="ThrustLabel" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,200,0,0" Width="200"/>
    </Grid>
</Window>